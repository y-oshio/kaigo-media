{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "jsonld-output.schema.json",
  "title": "JsonldOutput — schema-generator → publish-manager",
  "type": "object",
  "required": ["kwId", "blocks", "validation"],
  "additionalProperties": false,
  "properties": {
    "kwId": { "type": "string" },
    "blocks": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["type", "jsonld"],
        "properties": {
          "type": { "enum": ["Article", "BreadcrumbList", "FAQPage"] },
          "jsonld": { "type": "object", "required": ["@context", "@type"] }
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["syntaxOk", "requiredPropsOk", "contentMatchOk"],
      "properties": {
        "syntaxOk": { "type": "boolean" },
        "requiredPropsOk": { "type": "boolean" },
        "contentMatchOk": { "type": "boolean", "description": "マークアップ内容が可視コンテンツと一致" },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
